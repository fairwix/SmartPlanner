{
    "ConnectionStrings": {
        "PostgreSQL": "Host=localhost;Port=5432;Database=smartplanner;Username=postgres;Password=postgres;"
    },

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Microsoft.EntityFrameworkCore": "Warning",
            "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
            "Microsoft.AspNetCore.RateLimiting": "Information",
            "System": "Warning"
        },
        "Console": {
            "LogLevel": {
                "Default": "Information"
            },
            "FormatterName": "Simple",
            "FormatterOptions": {
                "TimestampFormat": "HH:mm:ss "
            }
        }
    },

    "JwtSettings": {
        "Secret": "your-32-character-secret-key-change-in-production",
        "Issuer": "smartplanner-api",
        "Audience": "smartplanner-clients",
        "AccessTokenExpirationMinutes": 15,
        "RefreshTokenExpirationDays": 7,
        "ValidateLifetime": true
    },

    "CorsSettings": {
        "AllowedOrigins": ["http://localhost:3000", "http://localhost:5173"],
        "AllowedMethods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
        "AllowedHeaders": ["Authorization", "Content-Type"],
        "AllowCredentials": true
    },

    "RateLimitSettings": {
        "EnableRateLimiting": true,
        "PermitLimit": 100,
        "WindowSeconds": 60,
        "QueueLimit": 2,

        "LoginRateLimit": {
            "Endpoint": "POST:/api/auth/login",
            "Period": "5m",
            "Limit": 5
        },

        "RegistrationRateLimit": {
            "Endpoint": "POST:/api/auth/register",
            "Period": "1h",
            "Limit": 3
        }
    },

    "EmailSettings": {
        "UseFileSystem": true,
        "FileSystemPath": "Emails",
        "SenderEmail": "noreply@smartplanner.com",
        "SenderName": "Smart Planner",

        "SmtpServer": "smtp.gmail.com",
        "SmtpPort": 587,
        "RequiresAuthentication": false,
        "UseSsl": true
    },

    "AppSettings": {
        "AppName": "Smart Planner",
        "BaseUrl": "https://localhost:7276",
        "Environment": "Development",

        "FrontendUrls": {
            "LoginUrl": "http://localhost:3000/login",
            "DashboardUrl": "http://localhost:3000/dashboard",
            "ResetPasswordUrl": "http://localhost:3000/reset-password",
            "ConfirmEmailUrl": "http://localhost:3000/confirm-email"
        },

        "Security": {
            "PasswordMinLength": 8,
            "RequireEmailConfirmation": false
        }
    },

    "AllowedHosts": "*"
}
